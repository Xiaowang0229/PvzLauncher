<Window x:Class="ExecuteShell.Windows.WindowMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExecuteShell.Windows"
        xmlns:icons="clr-namespace:ExecuteShell.Controls.Icons"
        mc:Ignorable="d"
        Title="PvzLauncher - Shell" Height="500 " Width="500" WindowStyle="None" Background="{x:Null}" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" ShowInTaskbar="True" AllowsTransparency="True" Topmost="True">
    <Grid>
        <icons:IconApplication x:Name="icon" Height="200" Opacity="0" Width="200" RenderTransformOrigin="0.5,0.5">
            <icons:IconApplication.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </icons:IconApplication.RenderTransform>
        </icons:IconApplication>
    </Grid>
</Window>
